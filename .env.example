# Environment variables for AI Game Shorts
# Copy this to .env and fill in your keys

# AI Provider Keys (choose one)
AI_GAME_SHORTS_OPENAI_KEY=your_openai_api_key_here
AI_GAME_SHORTS_GEMINI_KEY=your_gemini_api_key_here

# YouTube API
# After OAuth setup, this file is created automatically
AI_GAME_SHORTS_YOUTUBE_CLIENT_SECRET=config/youtube_credentials.json
AI_GAME_SHORTS_YOUTUBE_TOKEN=output/youtube_token.json

# Optional: Default game name (used when not detected automatically)
DEFAULT_GAME_NAME=AAA Game

# Processing options
AI_GAME_SHORTS_WHISPER_MODEL=base
AI_GAME_SHORTS_MAX_CLIPS=5
AI_GAME_SHORTS_DRY_RUN=false
